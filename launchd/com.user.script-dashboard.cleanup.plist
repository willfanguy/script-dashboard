<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.user.script-dashboard.cleanup</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/will/Repos/personal/script-dashboard/scripts/cleanup-runs.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/will/Repos/personal/script-dashboard</string>

    <!-- Run nightly at 03:15. StartCalendarInterval will catch up on next wake if the Mac was asleep. -->
    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>3</integer>
      <key>Minute</key>
      <integer>15</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/will/Library/Logs/script-dashboard/cleanup.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/will/Library/Logs/script-dashboard/cleanup.stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
  </dict>
</plist>
